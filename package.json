{
  "name": "paracosm",
  "version": "0.8.0",
  "description": "Prompt/document/URL-grounded structured world model for AI agents: typed ScenarioPackages, deterministic kernels, HEXACO actors, LLM events, runtime tool forging, and reproducible counterfactual RunArtifacts. Built on AgentOS.",
  "type": "module",
  "main": "dist/engine/index.js",
  "types": "dist/engine/index.d.ts",
  "bin": {
    "paracosm": "./dist/cli/run.js",
    "paracosm-dashboard": "./dist/cli/serve.js"
  },
  "exports": {
    ".": {
      "import": "./dist/engine/index.js",
      "types": "./dist/engine/index.d.ts"
    },
    "./mars": {
      "import": "./dist/engine/mars/index.js",
      "types": "./dist/engine/mars/index.d.ts"
    },
    "./runtime": {
      "import": "./dist/runtime/index.js",
      "types": "./dist/runtime/index.d.ts"
    },
    "./lunar": {
      "import": "./dist/engine/lunar/index.js",
      "types": "./dist/engine/lunar/index.d.ts"
    },
    "./core": {
      "import": "./dist/engine/core/state.js",
      "types": "./dist/engine/core/state.d.ts"
    },
    "./compiler": {
      "import": "./dist/engine/compiler/index.js",
      "types": "./dist/engine/compiler/index.d.ts"
    },
    "./schema": {
      "import": "./dist/engine/schema/index.js",
      "types": "./dist/engine/schema/index.d.ts"
    },
    "./world-model": {
      "import": "./dist/runtime/world-model/index.js",
      "types": "./dist/runtime/world-model/index.d.ts"
    },
    "./digital-twin": {
      "import": "./dist/engine/digital-twin/index.js",
      "types": "./dist/engine/digital-twin/index.d.ts"
    },
    "./leader-presets": {
      "import": "./dist/engine/leader-presets.js",
      "types": "./dist/engine/leader-presets.d.ts"
    }
  },
  "files": [
    "dist/",
    "config/leaders.example.json",
    "config/leaders.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli/run.js dist/cli/serve.js 2>/dev/null || true",
    "run": "npx tsx src/cli/run.ts",
    "run:a": "npx tsx src/cli/run-a.ts",
    "run:b": "npx tsx src/cli/run-b.ts",
    "smoke": "npx tsx src/cli/run-a.ts 3",
    "compare": "npx tsx src/cli/run-a.ts && npx tsx src/cli/run-b.ts",
    "dashboard": "npx tsx src/cli/serve.ts",
    "dashboard:dev": "cd src/cli/dashboard && npx vite",
    "dashboard:build": "cd src/cli/dashboard && npx vite build",
    "dashboard:smoke": "npx tsx src/cli/serve.ts 3",
    "compile": "npx tsx src/cli/compile.ts",
    "check:dashboard": "node --check src/cli/dashboard/main.legacy.js",
    "typecheck:dashboard": "tsc -p src/cli/dashboard",
    "test": "npm run typecheck:dashboard && node --import tsx --import ./scripts/test-css-stub.mjs --test 'tests/**/*.test.ts' 'src/cli/dashboard/src/**/*.test.ts' 'src/cli/dashboard/src/**/*.test.tsx'",
    "docs": "typedoc && cp assets/docs-theme/paracosm-override.css docs/api/assets/paracosm-override.css",
    "changelog": "node scripts/generate-changelog.mjs",
    "export:json-schema": "npx tsx scripts/export-json-schema.ts",
    "snapshot:schema": "npx tsx scripts/snapshot-schema.ts",
    "prepublishOnly": "npm run build",
    "leader:a": "npx tsx src/cli/run-a.ts",
    "leader:b": "npx tsx src/cli/run-b.ts"
  },
  "dependencies": {
    "@framers/agentos": "^0.5.12",
    "@framers/sql-storage-adapter": "^0.6.3",
    "better-sqlite3": "^12.9.0",
    "pdfjs-dist": "^5.7.284",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "paracosm",
    "world-model",
    "structured-world-model",
    "llm-world-model",
    "llm-readable-world-model",
    "prompt-to-world-model",
    "prompt-to-simulation",
    "http-api",
    "counterfactual-simulation",
    "cwsm",
    "digital-twin",
    "decision-simulation",
    "simulation",
    "multi-agent",
    "ai-agents",
    "llm-agents",
    "agent-based-modeling",
    "emergent-behavior",
    "tool-forging",
    "hexaco",
    "personality",
    "agentos",
    "typescript"
  ],
  "author": "Manic Agency LLC <team@frame.dev>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/framersai/paracosm"
  },
  "homepage": "https://agentos.sh"
}
