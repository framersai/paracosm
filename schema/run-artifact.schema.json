{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "runId": {
          "type": "string",
          "minLength": 1
        },
        "scenario": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "name"
          ],
          "additionalProperties": false
        },
        "seed": {
          "type": "integer",
          "minimum": -9007199254740991,
          "maximum": 9007199254740991
        },
        "mode": {
          "type": "string",
          "enum": [
            "turn-loop",
            "batch-trajectory",
            "batch-point"
          ]
        },
        "startedAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
        },
        "completedAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
        },
        "scenarioExtensions": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {}
        }
      },
      "required": [
        "runId",
        "scenario",
        "mode",
        "startedAt"
      ],
      "additionalProperties": false
    },
    "overview": {
      "type": "string"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "leveragePoints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "disclaimer": {
      "type": "string"
    },
    "trajectory": {
      "type": "object",
      "properties": {
        "timeUnit": {
          "type": "object",
          "properties": {
            "singular": {
              "type": "string",
              "minLength": 1
            },
            "plural": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "singular",
            "plural"
          ],
          "additionalProperties": false
        },
        "points": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "time": {
                "type": "number"
              },
              "metrics": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "number"
                }
              },
              "scenarioExtensions": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {}
              }
            },
            "required": [
              "time",
              "metrics"
            ],
            "additionalProperties": false
          }
        },
        "timepoints": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "time": {
                "type": "number"
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "narrative": {
                "type": "string"
              },
              "score": {
                "type": "object",
                "properties": {
                  "value": {
                    "type": "number"
                  },
                  "min": {
                    "type": "number"
                  },
                  "max": {
                    "type": "number"
                  },
                  "label": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "value",
                  "min",
                  "max",
                  "label"
                ],
                "additionalProperties": false
              },
              "highlightMetrics": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "label": {
                      "type": "string",
                      "minLength": 1
                    },
                    "value": {
                      "type": "string",
                      "minLength": 1
                    },
                    "direction": {
                      "type": "string",
                      "enum": [
                        "up",
                        "down",
                        "stable"
                      ]
                    },
                    "color": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "label",
                    "value"
                  ],
                  "additionalProperties": false
                }
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "reasoning": {
                "type": "string"
              },
              "worldSnapshot": {
                "type": "object",
                "properties": {
                  "metrics": {
                    "type": "object",
                    "propertyNames": {
                      "type": "string"
                    },
                    "additionalProperties": {
                      "type": "number"
                    }
                  },
                  "capacities": {
                    "type": "object",
                    "propertyNames": {
                      "type": "string"
                    },
                    "additionalProperties": {
                      "type": "number"
                    }
                  },
                  "statuses": {
                    "type": "object",
                    "propertyNames": {
                      "type": "string"
                    },
                    "additionalProperties": {
                      "anyOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "boolean"
                        }
                      ]
                    }
                  },
                  "politics": {
                    "type": "object",
                    "propertyNames": {
                      "type": "string"
                    },
                    "additionalProperties": {
                      "anyOf": [
                        {
                          "type": "number"
                        },
                        {
                          "type": "string"
                        },
                        {
                          "type": "boolean"
                        }
                      ]
                    }
                  },
                  "environment": {
                    "type": "object",
                    "propertyNames": {
                      "type": "string"
                    },
                    "additionalProperties": {
                      "anyOf": [
                        {
                          "type": "number"
                        },
                        {
                          "type": "string"
                        },
                        {
                          "type": "boolean"
                        }
                      ]
                    }
                  },
                  "scenarioExtensions": {
                    "type": "object",
                    "propertyNames": {
                      "type": "string"
                    },
                    "additionalProperties": {}
                  }
                },
                "required": [
                  "metrics"
                ],
                "additionalProperties": false
              },
              "scenarioExtensions": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {}
              }
            },
            "required": [
              "time",
              "label"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "timeUnit"
      ],
      "additionalProperties": false
    },
    "specialistNotes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "trajectory": {
            "type": "string",
            "enum": [
              "positive",
              "mixed",
              "negative",
              "neutral"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "detail": {
            "type": "object",
            "properties": {
              "risks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "severity": {
                      "type": "string",
                      "enum": [
                        "low",
                        "medium",
                        "high",
                        "critical"
                      ]
                    },
                    "description": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "severity",
                    "description"
                  ],
                  "additionalProperties": false
                }
              },
              "opportunities": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "impact": {
                      "type": "string",
                      "enum": [
                        "low",
                        "medium",
                        "high"
                      ]
                    },
                    "description": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "required": [
                    "impact",
                    "description"
                  ],
                  "additionalProperties": false
                }
              },
              "recommendedActions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "citations": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "text": {
                      "type": "string",
                      "minLength": 1
                    },
                    "url": {
                      "type": "string",
                      "minLength": 1
                    },
                    "doi": {
                      "type": "string"
                    },
                    "context": {
                      "default": "",
                      "type": "string"
                    }
                  },
                  "required": [
                    "text",
                    "url",
                    "context"
                  ],
                  "additionalProperties": false
                }
              },
              "openQuestions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          },
          "scenarioExtensions": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        },
        "required": [
          "domain",
          "summary"
        ],
        "additionalProperties": false
      }
    },
    "riskFlags": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "detail": {
            "type": "string",
            "minLength": 1
          },
          "scenarioExtensions": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        },
        "required": [
          "label",
          "severity",
          "detail"
        ],
        "additionalProperties": false
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "time": {
            "type": "number"
          },
          "actor": {
            "type": "string"
          },
          "choice": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string"
          },
          "reasoning": {
            "type": "string"
          },
          "outcome": {
            "type": "string",
            "enum": [
              "risky_success",
              "risky_failure",
              "conservative_success",
              "conservative_failure"
            ]
          },
          "scenarioExtensions": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        },
        "required": [
          "time",
          "choice"
        ],
        "additionalProperties": false
      }
    },
    "finalState": {
      "type": "object",
      "properties": {
        "metrics": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "number"
          }
        },
        "capacities": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "number"
          }
        },
        "statuses": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "boolean"
              }
            ]
          }
        },
        "politics": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "string"
              },
              {
                "type": "boolean"
              }
            ]
          }
        },
        "environment": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "string"
              },
              {
                "type": "boolean"
              }
            ]
          }
        },
        "scenarioExtensions": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {}
        }
      },
      "required": [
        "metrics"
      ],
      "additionalProperties": false
    },
    "fingerprint": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "string"
          }
        ]
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "doi": {
            "type": "string"
          },
          "context": {
            "default": "",
            "type": "string"
          }
        },
        "required": [
          "text",
          "url",
          "context"
        ],
        "additionalProperties": false
      }
    },
    "forgedTools": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "department": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "approved": {
            "type": "boolean"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "required": [
          "name",
          "approved"
        ],
        "additionalProperties": false
      }
    },
    "cost": {
      "type": "object",
      "properties": {
        "totalUSD": {
          "type": "number",
          "minimum": 0
        },
        "llmCalls": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "inputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "outputTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "cachedReadTokens": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "cacheSavingsUSD": {
          "type": "number",
          "minimum": 0
        },
        "breakdown": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "number"
          }
        }
      },
      "required": [
        "totalUSD"
      ],
      "additionalProperties": false
    },
    "providerError": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "auth",
                "quota",
                "rate_limit",
                "network",
                "unknown"
              ]
            },
            "provider": {
              "type": "string",
              "minLength": 1
            },
            "message": {
              "type": "string"
            },
            "actionUrl": {
              "type": "string",
              "format": "uri"
            }
          },
          "required": [
            "kind",
            "provider",
            "message"
          ],
          "additionalProperties": false
        },
        {
          "type": "null"
        }
      ]
    },
    "aborted": {
      "type": "boolean"
    },
    "scenarioExtensions": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "metadata"
  ],
  "additionalProperties": false
}
