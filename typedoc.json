{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src/index.ts",
    "src/engine/core/state.ts",
    "src/engine/compiler/index.ts",
    "src/engine/schema/index.ts",
    "src/engine/digital-twin/index.ts",
    "src/runtime/swarm/index.ts"
  ],
  "entryPointStrategy": "resolve",
  "out": "docs/api",
  "tsconfig": "tsconfig.build.json",
  "exclude": ["**/*.test.ts"],
  "skipErrorChecking": true,
  "cleanOutputDir": true,
  "name": "paracosm",
  "readme": "README.md",
  "includeVersion": true,
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "categorizeByGroup": true,
  "groupOrder": ["Classes", "Interfaces", "Functions", "Types", "Variables"]
}
